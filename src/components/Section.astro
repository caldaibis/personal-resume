---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<section class="mt-9">
  <div class="mb-5 flex items-center gap-3">
    <span class="h-2.5 w-2.5 shrink-0 bg-accent"></span>
    <h2 class="font-mono text-xs font-medium uppercase tracking-[0.25em] text-ink">
      {title}
    </h2>
    <span class="h-px flex-1 bg-line"></span>
  </div>
  <slot />
</section>
